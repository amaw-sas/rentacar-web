# Firebase Admin SDK Configuration
# Get these from: Firebase Console > Project Settings > Service Accounts > Generate new private key
NUXT_FIREBASE_PROJECT_ID=your-project-id
NUXT_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
NUXT_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
NUXT_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Blog API Security
# Generate a strong random API key (e.g., using: openssl rand -base64 32)
NUXT_BLOG_API_KEY=change-me-super-secret-key
# Comma-separated list of allowed IP addresses (e.g., "203.0.113.5,203.0.113.10")
NUXT_BLOG_API_ALLOWED_IPS=203.0.113.5

# SEO Dashboard (existing)
NUXT_SEO_PASSWORD=

# Google Search Console OAuth (existing)
NUXT_GSC_CLIENT_ID=
NUXT_GSC_CLIENT_SECRET=
NUXT_GSC_REDIRECT_URI=
